# リポジトリ内の改行コードは LF で統一する
# チェックアウト時の改行は core.autocrlf / core.eol に委ねる
* text=auto eol=lf

# ソース / 設定 / ドキュメント（LF 固定）
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf
*.sql      text eol=lf
*.prisma   text eol=lf
*.sh       text eol=lf
*.svg      text eol=lf
.env*      text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows 専用スクリプトは CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ロックファイル（npm / yarn / pnpm）
package-lock.json text eol=lf
yarn.lock         text eol=lf
pnpm-lock.yaml    text eol=lf

# バイナリ
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
*.otf      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.7z       binary
*.mp4      binary
*.mov      binary
